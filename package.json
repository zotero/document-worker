{
	"name": "document-worker",
	"version": "1.0.0",
	"description": "A document processing toolkit that runs on Node.js and Web Worker",
	"exports": {
		".": "./src/index.js",
		"./pdf": "./src/pdf/index.js",
		"./build/*": "./build/*"
	},
	"scripts": {
		"build": "npm run build:assets && npm run build:worker",
		"build:assets": "sh scripts/build-assets",
		"build:worker": "webpack --mode production",
		"dev:worker": "webpack --mode development",
		"dev:preview": "npm run dev --prefix preview",
		"test": "node --test test/*.js",
		"test:jscontext": "bash test/jscontext/run-tests.sh",
		"test:update-structured": "UPDATE_SNAPSHOTS=1 node --test test/getStructure.test.js"
	},
	"type": "module",
	"author": "Martynas Bagdonas",
	"license": "AGPL-3.0",
	"dependencies": {
		"fastest-levenshtein": "^1.0.16",
		"pako": "2.1.0"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.4",
		"@eslint/js": "^10.0.1",
		"@zotero/eslint-config": "^1.0.9",
		"canvas": "^3.2.1",
		"eslint": "^10.0.2",
		"json-stringify-pretty-compact": "^4.0.0",
		"webpack": "^5.105.3",
		"webpack-cli": "^6.0.1"
	}
}
