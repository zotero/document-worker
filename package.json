{
	"name": "document-worker",
	"version": "1.0.0",
	"description": "A document processing toolkit that runs on Node.js and Web Worker",
	"main": "./src/index.js",
	"exports": {
		".": "./src/index.js",
		"./pdf": "./src/pdf/index.js",
		"./build/*": "./build/*"
	},
	"scripts": {
		"build": "run-p build:assets build:worker",
		"build:assets": "sh scripts/build-assets",
		"build:worker": "webpack --mode production",
		"dev:worker": "webpack --mode development",
		"dev:preview": "npm run dev --prefix preview",
		"test": "node --import ./scripts/pdfjs-setup.js node_modules/.bin/mocha",
		"test:jscontext": "bash test/jscontext/run-tests.sh"
	},
	"browserslist": [
		"last 2 versions",
		"not dead",
		"> 0.2%"
	],
	"type": "module",
	"author": "Martynas Bagdonas",
	"license": "AGPL-3.0",
	"dependencies": {
		"core-js": "^3.37.1",
		"fastest-levenshtein": "^1.0.16",
		"pako": "2.1.0"
	},
	"devDependencies": {
		"@babel/core": "^7.24.6",
		"@babel/eslint-parser": "^7.22.5",
		"@babel/preset-env": "^7.24.6",
		"@zotero/eslint-config": "^1.0.7",
		"babel-loader": "^9.1.3",
		"canvas": "^3.2.1",
		"chai": "^4.3.7",
		"eslint": "^8.43.0",
		"mocha": "^10.2.0",
		"npm-run-all": "^4.1.5",
		"webpack": "^5.91.0",
		"webpack-cli": "^5.1.4"
	}
}
