#!/bin/bash
# Copy binary/static assets to build/ for external loading

set -euo pipefail

rm -rf build/wasm build/onnx build/block-seg build/table-grid

# pdf.js assets
mkdir -p build/cmaps
rsync -a --delete --exclude='.*' pdf.js/external/bcmaps/ build/cmaps/
mkdir -p build/standard_fonts
rsync -a --delete --exclude='.*' pdf.js/external/standard_fonts/ build/standard_fonts/
mkdir -p build/wasm
cp pdf.js/external/openjpeg/openjpeg.wasm build/wasm/

# ONNX runtime
mkdir -p build/onnx
cp src/pdf/structure/model/onnx/ort-wasm-simd.wasm build/onnx/

# ML model binaries
mkdir -p build/block-seg/clusterer
cp src/pdf/structure/model/block-seg/clusterer/model.onnx build/block-seg/clusterer/
cp src/pdf/structure/model/block-seg/clusterer/repair.onnx build/block-seg/clusterer/
cp src/pdf/structure/model/block-seg/clusterer/runtime.bin build/block-seg/clusterer/
mkdir -p build/block-seg/classifier
cp src/pdf/structure/model/block-seg/classifier/model.onnx build/block-seg/classifier/
cp src/pdf/structure/model/block-seg/classifier/stats.bin build/block-seg/classifier/
