{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ES2020",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"outDir": "build",
		"rootDir": "src",
		"skipLibCheck": true
	},
	"include": ["src/**/*.ts", "structured-document-text/schema.d.ts", "structured-document-text/src/**/*.d.ts"]
}
